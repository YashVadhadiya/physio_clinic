PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Database type: 'google_sheets' (default) or 'supabase'
DATABASE_TYPE=google_sheets

# Google Sheets via Apps Script
# Deploy the AppsScript.gs to your Google Sheet, then paste the web app URL here
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
APPS_SCRIPT_TOKEN=your-secret-token

# Supabase (only needed if DATABASE_TYPE=supabase)
# Create a project at https://supabase.com, run supabase-schema.sql in SQL Editor
# Copy these from Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Admin Default
ADMIN_EMAIL=admin@physioclinic.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Dr. Admin
ADMIN_MOBILE=+1234567890
